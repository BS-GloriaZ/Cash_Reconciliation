# Virtual environment
.venv/

# Python cache
__pycache__/
.pytest_cache/
*.pyc
*.pyo

# Windows ADS metadata
*:Zone.Identifier

# Local machine config (contains network share paths)
src/cash_rec/config/config.local.yaml

# Input data — sensitive financial data synced via sync_inputs.py / sync_inputs.ps1
data/input/bnp/*
data/input/bnp_margin_pdf/*
data/input/bnp_nz/*
data/input/citi/*
data/input/citi_hi/*
data/input/mapping/*
data/input/reference/*
data/input/tradar/*
!data/input/**/.gitkeep

# Output data — generated by the pipeline, not source-controlled
data/output/

# Build / packaging artifacts
src/*.egg-info/

# Excel temp files
~$*.xlsx
~$*.xls

# Frontend build outputs and generated Excel files served for demo
recx-frontend/public/outputs/*.xlsx
recx-frontend/public/outputs/*.xls
recx-frontend/public/outputs/manifest.json
